------------------------------------------------------------
-- Phantom World
-- Toggleable invisibility via button
-- Appears when ice cream is anywhere in inventory
------------------------------------------------------------

local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer  = Players.LocalPlayer
local PlayerGui    = LocalPlayer.PlayerGui
local Camera       = workspace.CurrentCamera

local ICECREAM_KEYWORDS = {"ice", "cream", "cone"}
local INVIS_COOLDOWN    = 60

------------------------------------------------------------
-- Keyword matcher
------------------------------------------------------------
local function matchesAny(name, keywords)
    local lower = string.lower(name)
    for _, kw in ipairs(keywords) do
        if string.find(lower, kw) then return true end
    end
    return false
end

------------------------------------------------------------
-- Check if ice cream is anywhere in inventory
------------------------------------------------------------
local function hasIceCreamInInventory()
    local char = LocalPlayer.Character
    if not char then return false end

    for _, item in ipairs(char:GetChildren()) do
        if item:IsA("Tool") and matchesAny(item.Name, ICECREAM_KEYWORDS) then
            return true
        end
    end

    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            if item:IsA("Tool") and matchesAny(item.Name, ICECREAM_KEYWORDS) then
                return true
            end
        end
    end

    return false
end

------------------------------------------------------------
-- State
------------------------------------------------------------
local isInvisible = false
local clone       = nil
local cloneThread = nil
local onCooldown  = false

------------------------------------------------------------
-- Cleanup clone
------------------------------------------------------------
local function cleanupClone()
    if clone then
        clone:Destroy()
        clone = nil
    end
    if cloneThread then
        task.cancel(cloneThread)
        cloneThread = nil
    end
end

------------------------------------------------------------
-- Restore real body
------------------------------------------------------------
local function restoreBody(teleportToClone)
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")

    -- Teleport back to clone position
    if teleportToClone and clone and clone.PrimaryPart then
        if hrp then
            hrp.CFrame = clone.PrimaryPart.CFrame
        end
    end

    -- Restore visibility and collision
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 0
            part.CanCollide   = true
        end
    end

    -- Restore camera
    if hum then
        Camera.CameraSubject = hum
        Camera.CameraType    = Enum.CameraType.Custom
    end
end

------------------------------------------------------------
-- Activate Phantom World
------------------------------------------------------------
local function activatePhantom()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    isInvisible = true
    local originalCFrame = hrp.CFrame

    -- Create clone at current position
    clone        = Instance.new("Model")
    clone.Name   = "PhantomClone"
    clone.Parent = workspace

    local partMap = {}
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            local clonePart                         = part:Clone()
            clonePart.Transparency                  = 0.5
            clonePart.CanCollide                    = true
            clonePart.Anchored                      = false
            clonePart.AssemblyLinearVelocity        = Vector3.zero
            clonePart.AssemblyAngularVelocity       = Vector3.zero
            clonePart.Parent                        = clone
            partMap[part]                           = clonePart
        end
    end

    local cloneHRP = partMap[hrp]
    if not cloneHRP then
        cleanupClone()
        isInvisible = false
        return
    end

    cloneHRP.CFrame  = originalCFrame
    clone.PrimaryPart = cloneHRP

    -- Weld clone parts together
    for origPart, clonePart in pairs(partMap) do
        if clonePart ~= cloneHRP then
            local weld   = Instance.new("WeldConstraint")
            weld.Part0   = cloneHRP
            weld.Part1   = clonePart
            weld.Parent  = cloneHRP
            local offset = hrp.CFrame:ToObjectSpace(origPart.CFrame)
            clonePart.CFrame = cloneHRP.CFrame * offset
        end
    end

    -- Give clone humanoid for physics/gravity
    local cloneHum      = Instance.new("Humanoid")
    cloneHum.WalkSpeed  = 0
    cloneHum.JumpPower  = 0
    cloneHum.Parent     = clone

    -- Teleport real body 750 studs up
    hrp.CFrame = originalCFrame * CFrame.new(0, 750, 0)

    -- Hide real body
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 1
            part.CanCollide   = false
        end
    end

    -- Lock camera to clone head
    local cloneHead      = clone:FindFirstChild("Head") or cloneHRP
    Camera.CameraSubject = cloneHead
    Camera.CameraType    = Enum.CameraType.Custom

    -- Mirror movement from real body to clone
    local lastHRPCFrame = hrp.CFrame
    cloneThread = task.spawn(function()
        while isInvisible do
            local currentCFrame = hrp.CFrame
            local deltaPos      = currentCFrame.Position - lastHRPCFrame.Position
            deltaPos            = Vector3.new(deltaPos.X, 0, deltaPos.Z)
            cloneHRP.CFrame     = cloneHRP.CFrame * CFrame.new(deltaPos)
            lastHRPCFrame       = currentCFrame
            task.wait()
        end
    end)

    print("[Phantom World] Activated")
end

------------------------------------------------------------
-- Deactivate Phantom World
------------------------------------------------------------
local function deactivatePhantom()
    if not isInvisible then return end
    isInvisible = false

    restoreBody(true)
    cleanupClone()

    print("[Phantom World] Deactivated")
end

------------------------------------------------------------
-- GUI
------------------------------------------------------------
local screenGui = Instance.new("ScreenGui")
screenGui.Name           = "PhantomGui"
screenGui.ResetOnSpawn   = false
screenGui.IgnoreGuiInset = true
