cdLabel.TextScaled             = true
cdLabel.Font                   = Enum.Font.GothamBold
cdLabel.Text                   = ""
cdLabel.Visible                = false
cdLabel.Parent                 = phantomBtn

------------------------------------------------------------
-- Cooldown (only starts when toggled OFF)
------------------------------------------------------------
local function startCooldown()
    onCooldown = true
    phantomBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    phantomBtn.Text             = ""
    cdLabel.Visible             = true

    local remaining = INVIS_COOLDOWN
    while remaining > 0 do
        cdLabel.Text = tostring(remaining)
        task.wait(1)
        remaining   -= 1
    end

    cdLabel.Visible             = false
    cdLabel.Text                = ""
    phantomBtn.Text             = "Phantom\nWorld"
    phantomBtn.BackgroundColor3 = Color3.fromRGB(100, 20, 180)
    onCooldown = false
end

------------------------------------------------------------
-- Toggle on click
------------------------------------------------------------
phantomBtn.MouseButton1Click:Connect(function()
    if onCooldown then return end

    if isInvisible then
        -- Toggle OFF
        deactivatePhantom()
        task.spawn(startCooldown)
        phantomBtn.BackgroundColor3 = Color3.fromRGB(100, 20, 180)
        phantomBtn.Text             = "Phantom\nWorld"
    else
        -- Toggle ON
        if not hasIceCreamInInventory() then return end
        phantomBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 255)
        phantomBtn.Text             = "Phantom\nON"
        task.spawn(activatePhantom)
    end
end)

------------------------------------------------------------
-- Show button only when ice cream is in inventory
------------------------------------------------------------
RunService.Heartbeat:Connect(function()
    if onCooldown then return end
    phantomBtn.Visible = hasIceCreamInInventory()
end)

print("[Phantom World] Ready")
