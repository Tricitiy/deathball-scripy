phantomBtn.AnchorPoint      = Vector2.new(0, 0.5)
phantomBtn.BackgroundColor3 = Color3.fromRGB(100, 20, 180)
phantomBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
phantomBtn.Text             = "Phantom\nWorld"
phantomBtn.TextScaled       = true
phantomBtn.Font             = Enum.Font.GothamBold
